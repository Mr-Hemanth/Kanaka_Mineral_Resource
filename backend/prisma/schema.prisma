generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int                 @id @default(autoincrement())
  name            String
  email           String              @unique
  password        String
  role            String              @default("SUPERVISOR") // ADMIN, SUPERVISOR, OWNER
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  ActivityLogs    ActivityLog[]
  DieselLogs      DieselLog[]         @relation("SupervisorLogs")
  PurchaseOrders  PurchaseOrder[]
  InventoryItems  InventoryItem[]
}

model Vehicle {
  id              Int           @id @default(autoincrement())
  vehicleNumber   String        @unique
  driverName      String?
  vehicleType     String
  mileage         Float?
  lastServiceDate DateTime?
  nextServiceDate DateTime?
  status          String        @default("ACTIVE") // ACTIVE, MAINTENANCE, INACTIVE
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  DieselLogs      DieselLog[]
  Maintenances    Maintenance[]
  VehicleTrips    VehicleTrip[]
}

model Driver {
  id            Int             @id @default(autoincrement())
  name          String
  licenseNumber String?         @unique
  phone         String?
  status        String          @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  TruckDispatches TruckDispatch[]
}

model DieselLog {
  id            Int      @id @default(autoincrement())
  date          DateTime @default(now())
  vehicleId     Int?
  vehicle       Vehicle? @relation(fields: [vehicleId], references: [id])
  type          String   @default("FILLED") // FILLED or BOUGHT
  dieselFilled  Float
  pricePerLitre Float
  totalCost     Float
  supplier      String?  // For purchased diesel
  location      String?  // Where diesel was purchased
  remarks       String?
  supervisorId  Int
  supervisor    User     @relation("SupervisorLogs", fields: [supervisorId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
  @@index([vehicleId])
}

model TruckDispatch {
  id              Int           @id @default(autoincrement())
  date            DateTime      @default(now())
  truckNumber     String
  driverId        Int?
  driver          Driver?       @relation(fields: [driverId], references: [id])
  materialType    String
  tonnage         Float
  destination     String
  buyer           String?
  pricePerTon     Float
  totalRevenue    Float
  
  // PO Integration
  purchaseOrderId Int?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderItemId Int?
  purchaseOrderItem PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])
  
  // Payment Fields
  transportPricePerTon Float
  totalTransportValue  Float
  advanceAmount        Float
  balanceAmount        Float
  advancePaid          Boolean @default(false)
  balancePaid          Boolean @default(false)
  paymentStatus        String  @default("PENDING") // PENDING, ADVANCE_PAID, BALANCE_PAID, FULLY_PAID
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([date])
  @@index([materialType])
  @@index([truckNumber])
}

model Expense {
  id            Int      @id @default(autoincrement())
  date          DateTime @default(now())
  category      String   // DIESEL, LABOUR, DRIVER, MACHINE_REPAIR, SPARE_PARTS, TRANSPORT, OTHER
  amount        Float
  paymentMethod String?
  description   String?
  voucherNo     String?  // Voucher number for tracking
  paidTo        String?  // Person/entity being paid
  paidBy        String?  // Person who made the payment
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
  @@index([category])
}

model Maintenance {
  id                 Int      @id @default(autoincrement())
  vehicleId          Int?
  vehicle            Vehicle? @relation(fields: [vehicleId], references: [id])
  machineId          Int?
  machine            Machine? @relation(fields: [machineId], references: [id])
  partReplaced       String
  cost               Float
  date               DateTime @default(now())
  nextMaintenanceDue DateTime?
  inventoryItemId    Int?
  inventoryItem      InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  quantityUsed       Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Worker {
  id            Int         @id @default(autoincrement())
  name          String
  role          String      // e.g., DRILLER, LOADER, CHECKER, ELECTRICIAN
  contact       String?
  status        String      @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  WorkerLogs    WorkerLog[]
  MachineLogs   MachineLog[] // ADDED: Relation to MachineLog operator
}

model WorkerLog {
  id            Int      @id @default(autoincrement())
  workerId      Int
  worker        Worker   @relation(fields: [workerId], references: [id])
  date          DateTime @default(now())
  inTime        String?
  outTime       String?
  workType      String
  advancePayment Float   @default(0)
  balancePayment Float   @default(0)
  totalPayment   Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
  @@index([workerId])
}

model VehicleTrip {
  id              Int      @id @default(autoincrement())
  vehicleId       Int
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  date            DateTime @default(now())
  destination     String
  distance        Float?
  amountPaid      Float    @default(0)
  remarks         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([vehicleId])
}

model Machine {
  id            Int           @id @default(autoincrement())
  name          String
  type          String        // GENERATOR, COMPRESSOR, PUMP, CRUSHER, OTHER
  model         String?
  capacity      String?
  status        String        @default("OPERATIONAL") // OPERATIONAL, UNDER_REPAIR, OUT_OF_ORDER
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  MachineLogs   MachineLog[]
  Maintenances  Maintenance[]
}

model MachineLog {
  id            Int      @id @default(autoincrement())
  machineId     Int
  machine       Machine  @relation(fields: [machineId], references: [id])
  date          DateTime @default(now())
  hoursWorked   Float    @default(0)
  readingStart  Float?
  readingEnd    Float?
  operatorId    Int?
  operator      Worker?  @relation(fields: [operatorId], references: [id])
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
  @@index([machineId])
}

model Document {
  id         Int      @id @default(autoincrement())
  fileName   String
  fileUrl    String
  type       String   // ROYALTY_BILL, INVOICE, EWAY_BILL, TRANSPORT_DOC, OTHER
  uploadedAt DateTime @default(now())
}

model ActivityLog {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  action         String
  moduleAffected String
  timestamp      DateTime @default(now())
}

// Purchase Order Management
model PurchaseOrder {
  id              Int                @id @default(autoincrement())
  poNumber        String             @unique
  orderDate       DateTime           @default(now())
  deliveryDate    DateTime?
  buyerName       String             // Renamed from supplierName context
  supplierContact String?
  destination     String?            // Where to dispatch items to
  gstNo           String?            // GST Identification Number
  gstDetails      String?            // Additional GST details (state, rate, etc.)
  status          String             @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED, CANCELLED
  totalAmount     Float              @default(0)
  paymentTerms    String?
  notes           String?
  createdBy       Int
  user            User               @relation(fields: [createdBy], references: [id])
  items           PurchaseOrderItem[]
  TruckDispatches TruckDispatch[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model PurchaseOrderItem {
  id             Int             @id @default(autoincrement())
  purchaseOrderId Int
  purchaseOrder  PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  itemName       String
  itemType       String          // MATERIAL, EQUIPMENT, PARTS, FUEL, OTHER
  quantity       Float
  dispatchedQuantity Float       @default(0) // ADDED: track how much of this order has been dispatched
  unit           String          // LITERS, KG, PIECES, etc.
  unitPrice      Float
  totalPrice     Float
  specifications String?
  TruckDispatches TruckDispatch[] // Relation back to dispatches
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

// Inventory/Storage Management
model InventoryItem {
  id              Int      @id @default(autoincrement())
  itemName        String
  itemType        String   // SPARE_PART, TOOL, EQUIPMENT, CONSUMABLE, MATERIAL, OTHER
  category        String?  // ENGINE, ELECTRICAL, HYDRAULIC, TIRE, etc.
  partNumber      String?  // Manufacturer part number
  quantity        Float    @default(0)
  unit            String   @default("PIECES") // PIECES, LITERS, KG, METERS, etc.
  minStock        Float    @default(0)  // Minimum stock level for alerts
  maxStock        Float?   // Maximum stock level
  location        String?  // Storage room location (Rack A, Shelf B, etc.)
  supplier        String?  // Preferred supplier
  lastPurchasePrice Float? @default(0)
  totalValue      Float    @default(0)  // quantity * lastPurchasePrice
  description     String?
  status          String   @default("IN_STOCK") // IN_STOCK, LOW_STOCK, OUT_OF_STOCK, DISCONTINUED
  addedBy         Int?
  user            User?    @relation(fields: [addedBy], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  Maintenances    Maintenance[]
}


// Blasting Management
model BlastRecord {
  id              Int      @id @default(autoincrement())
  date            DateTime @default(now())
  blastNumber     String   // Unique blast identifier
  location        String   // Specific blast location
  totalHoles      Int      // Number of drill holes
  holeDepth       Float    // Depth in meters
  explosiveUsed   Float    // Total explosive in kg
  detonatorCount  Int      // Number of detonators
  powderFactor    Float    // Explosive per cubic meter (kg/m³)
  volumeBlasted   Float    // Volume blasted in m³
  chargePerHole   Float    // Average charge per hole
  stemmingLength  Float?   // Stemming length in meters
  blastingTime    DateTime? // Actual blast time
  supervisor      String?  // Blasting supervisor
  agency          String?  // Blasting agency/company
  weatherCondition String? // Weather during blast
  vibrationLevel  Float?   // Vibration level (if monitored)
  flyrockDistance Float?   // Flyrock distance observed
  safetyMeasures  String?  // Safety measures taken
  remarks         String?
  status          String   @default("COMPLETED") // PLANNED, COMPLETED, CANCELLED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
